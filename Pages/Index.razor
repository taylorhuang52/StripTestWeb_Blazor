@page "/"
@inject ReportService Svc
@inject IJSRuntime JS
@implements IDisposable

<div class="layout">

  <!-- ── Header ── -->
  <header class="app-header">
    <div>
      <div class="app-title">⬡ Strip Test Report Generator</div>
      <div class="app-sub">Blazor WASM Edition</div>
    </div>
  </header>

  <div class="body-wrap">

    <!-- ── Side panel ── -->
    <aside class="side-panel">

      <!-- Drop zone -->
      <div class="sec-label">LOG FILES</div>
      <!-- Drop zone: InputFile overlays the entire area -->
      <div class="drop-zone @(_dragOver ? "drag-over" : "")"
           style="position:relative;overflow:hidden"
           @ondragover="OnDragOver" @ondragover:preventDefault="true"
           @ondragleave="OnDragLeave"
           @ondrop="OnDrop" @ondrop:preventDefault="true">
        <div class="drop-icon">📂</div>
        <p><strong>Click to browse</strong> or drag & drop<br/>XLS / XLSX log files</p>
        <InputFile multiple OnChange="OnFilesSelected" accept=".xls,.xlsx"
                   style="position:absolute;top:0;left:0;width:100%;height:100%;
                          opacity:0;cursor:pointer;font-size:0" /></div>

      @if (Svc.Files.Count > 0 && !Svc.IsRunning)
      {
        <button class="btn btn-sm btn-dim" @onclick="Svc.ClearFiles">✕ Clear all</button>
      }

      <!-- Progress -->
      <div class="sec-label" style="margin-top:16px">PROGRESS</div>
      <div class="progress-track">
        <div class="progress-bar" style="width:@ProgressPct%"></div>
      </div>
      <div class="status-text @StatusClass">@StatusText</div>

      <!-- Summary -->
      <div class="sec-label" style="margin-top:16px">SUMMARY</div>
      <div class="stat-box">
        @if (Svc.Files.Count == 0)
        {
          <span style="color:var(--sub)">—</span>
        }
        else
        {
          <div>Files : <b>@Svc.Files.Count</b></div>
          <div>Done  : <b>@Svc.Files.Count(f => f.Status == FileStatus.Done)</b></div>
          <div>Input : <b>@Svc.TotalInput.ToString("N0")</b></div>
          <div>Output: <b>@Svc.TotalOutput.ToString("N0")</b></div>
          <div>Yield : <b>@Svc.TotalYield.ToString("P2")</b></div>
          <div>VTH&lt;1.5V: <b>@Svc.GoodResults.Sum(r=>r.VthLt15)</b></div>
          <div>VTH&gt;6V : <b>@Svc.GoodResults.Sum(r=>r.VthGt6)</b></div>
        }
      </div>

      <!-- Buttons -->
      <div style="margin-top:auto;display:flex;flex-direction:column;gap:8px;padding-top:16px">
        @if (Svc.IsRunning)
        {
          <div style="display:flex;gap:8px">
            <button class="btn btn-pause" @onclick="OnPause">
              @(Svc.IsPaused ? "▶ Resume" : "⏸ Pause")
            </button>
            <button class="btn btn-stop" @onclick="Svc.Stop">⏹ Stop</button>
          </div>
        }
        else if (Svc.Files.Count > 0 && Svc.GoodResults.Any())
        {
          <button class="btn btn-accent" @onclick="OnDownload">⬇ Download Report</button>
        }
        <button class="btn btn-green" disabled="@(Svc.IsRunning || Svc.Files.Count == 0)"
                @onclick="OnGenerate">
          ▶ Generate Report
        </button>
      </div>

    </aside>

    <!-- ── Main area ── -->
    <main class="main-area">
      <div class="sec-label" style="color:var(--accent);letter-spacing:1px;font-size:10px;margin-bottom:8px">
        LOG FILES
      </div>

      @if (Svc.Files.Count == 0)
      {
        <div class="empty-state">
          <div class="empty-icon">⬡</div>
          <div>Upload XLS / XLSX log files to begin</div>
        </div>
      }
      else
      {
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th style="text-align:left">File</th>
                <th>Status</th>
                <th>Input</th>
                <th>Output</th>
                <th>Yield</th>
                <th>VTH&lt;1.5V</th>
                <th>VTH&gt;6V</th>
                <th>Error</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var f in Svc.Files)
              {
                <tr class="@RowClass(f)">
                  <td style="text-align:left">@f.Name</td>
                  <td><span class="badge @BadgeClass(f.Status)">@BadgeText(f.Status)</span></td>
                  <td>@(f.Result?.Input.ToString() ?? "—")</td>
                  <td>@(f.Result?.Output.ToString() ?? "—")</td>
                  <td>@(f.Result?.Yield.ToString("P2") ?? "—")</td>
                  <td>@(f.Result?.VthLt15.ToString() ?? "—")</td>
                  <td>@(f.Result?.VthGt6.ToString() ?? "—")</td>
                  <td class="err-cell">@f.Result?.Error</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      }
    </main>
  </div>

  <!-- ── Footer ── -->
  <footer class="app-footer">
    @if (Svc.IsRunning) { <span class="spinner"></span> }
    <span>@StatusText</span>
  </footer>
</div>

@code {
  bool _dragOver = false;

  // ── Lifecycle ──────────────────────────────────────────────────
  protected override void OnInitialized()
  {
    Svc.StateChanged += OnStateChanged;
  }

  void OnStateChanged()
  {
    InvokeAsync(StateHasChanged);
  }

  public void Dispose()
  {
    Svc.StateChanged -= OnStateChanged;
  }

  // ── File input ─────────────────────────────────────────────────
  async Task OnFilesSelected(InputFileChangeEventArgs e)
  {
    var list = new List<(string, byte[])>();
    foreach (var f in e.GetMultipleFiles(200))
    {
      using var ms = new MemoryStream();
      await f.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
      list.Add((f.Name, ms.ToArray()));
    }
    Svc.AddFiles(list);
  }

  void OnDragOver()  => _dragOver = true;
  void OnDragLeave() => _dragOver = false;

  async Task OnDrop(DragEventArgs e)
  {
    _dragOver = false;
    // Read dropped files via JS interop
    await JS.InvokeVoidAsync("blazorDropHelper.handleDrop",
        DotNetObjectReference.Create(this), "filePicker");
  }

  [JSInvokable]
  public async Task ReceiveDroppedFile(string name, byte[] data)
  {
    Svc.AddFiles(new[] { (name, data) });
    await InvokeAsync(StateHasChanged);
  }

  // ── Actions ────────────────────────────────────────────────────
  async Task OnGenerate()
  {
    await Svc.RunAsync();
  }

  void OnPause()
  {
    if (Svc.IsPaused) Svc.Resume();
    else               Svc.Pause();
  }

  async Task OnDownload()
  {
    try
    {
      var bytes = Svc.GenerateReport();
      string fname = $"Strip_Test_Report_{DateTime.Today:yyyyMMdd}.xlsx";
      await JS.InvokeVoidAsync("blazorDropHelper.downloadFile", fname, bytes);
    }
    catch (Exception ex)
    {
      await JS.InvokeVoidAsync("alert", "Export error: " + ex.Message);
    }
  }

  // ── UI helpers ─────────────────────────────────────────────────
  double ProgressPct => Svc.Files.Count > 0
    ? (double)Svc.Progress / Svc.Files.Count * 100 : 0;

  string StatusText => Svc.IsRunning
    ? (Svc.IsPaused
        ? "⏸ Paused"
        : $"Processing {Svc.Progress} / {Svc.Files.Count}…")
    : Svc.Files.Count == 0
        ? "Ready — upload log files to begin."
        : Svc.GoodResults.Any()
            ? $"✓ Done — {Svc.GoodResults.Count()} lots processed"
            : $"{Svc.Files.Count} file(s) ready";

  string StatusClass => Svc.IsRunning && Svc.IsPaused ? "warn"
    : !Svc.IsRunning && Svc.GoodResults.Any()         ? "ok"
    : "";

  static string RowClass(FileEntry f) => f.Status switch
  {
    FileStatus.Done  => "row-done",
    FileStatus.Error => "row-error",
    _                => ""
  };

  static string BadgeClass(FileStatus s) => s switch
  {
    FileStatus.Waiting    => "badge-wait",
    FileStatus.Processing => "badge-proc",
    FileStatus.Done       => "badge-done",
    FileStatus.Error      => "badge-err",
    _                     => ""
  };

  static string BadgeText(FileStatus s) => s switch
  {
    FileStatus.Waiting    => "Ready",
    FileStatus.Processing => "⏳ Processing",
    FileStatus.Done       => "✓ Done",
    FileStatus.Error      => "✗ Error",
    _                     => ""
  };
}
